# Treat all text as auto-detected, normalize to LF in the repo
* text=auto eol=lf

# Binary types — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.icns binary
*.pdf binary
*.zip binary
*.gz binary
*.dll binary
*.exe binary
*.node binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.p8 binary
